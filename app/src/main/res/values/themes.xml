<resources>
    <!-- Base application theme. -->
    <style name="Theme.ASOTvPlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/midnight_black</item>
        <item name="colorPrimaryVariant">@color/deep_night</item>
        <item name="colorOnPrimary">@color/electric_violet</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/royal_indigo</item>
        <item name="colorSecondaryVariant">@color/plum_glow</item>
        <item name="colorOnSecondary">@color/electric_violet</item>


        <!-- Status bar -->
        <item name="android:statusBarColor">@color/deep_night</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="LoginButtonStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:padding">@dimen/_20sdp</item>
        <item name="cornerRadius">@dimen/_15sdp</item>
        <item name="iconGravity">top</item>
        <item name="iconPadding">@dimen/_20sdp</item>
        <item name="strokeWidth">@dimen/_1sdp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/beltic_sea</item>
        <item name="strokeColor">@color/flush_mahogany</item>
        <item name="android:includeFontPadding">false</item>

    </style>

    <style name="AppButtonStyleMahogany">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">@dimen/_10sdp</item>
        <item name="android:paddingBottom">@dimen/_10sdp</item>
        <item name="backgroundTint">@color/flush_mahogany</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/_10sdp</item>
        <item name="strokeWidth">@dimen/_1sdp</item>
        <item name="strokeColor">@color/flush_mahogany</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="AppButtonStyleIridium">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">@dimen/_10sdp</item>
        <item name="android:paddingBottom">@dimen/_10sdp</item>
        <item name="backgroundTint">@color/iridium</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/_10sdp</item>
        <item name="strokeWidth">@dimen/_1sdp</item>
        <item name="strokeColor">@color/iridium</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="DialogHeaderStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/storm_dust_alpha_65</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:gravity">center</item>

    </style>

    <style name="TextInputLayoutStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/_10sdp</item>
        <item name="boxStrokeColor">@color/storm_dust</item>
        <item name="boxStrokeWidthFocused">@dimen/_2sdp</item>
        <item name="boxStrokeWidth">@dimen/_1sdp</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/_10sdp</item>
        <item name="boxCornerRadiusBottomStart">@dimen/_10sdp</item>
        <item name="boxCornerRadiusTopEnd">@dimen/_10sdp</item>
        <item name="boxCornerRadiusTopStart">@dimen/_10sdp</item>
        <item name="boxBackgroundMode">outline</item>
        <item name="hintEnabled">false</item>

    </style>

    <style name="EditTextInputLayoutStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:paddingTop">@dimen/_10sdp</item>
        <item name="android:paddingBottom">@dimen/_10sdp</item>
        <item name="android:paddingStart">@dimen/_10sdp</item>
        <item name="android:paddingEnd">@dimen/_10sdp</item>
        <item name="android:textColorHint">@color/storm_dust_alpha_65</item>
        <item name="android:textColor">@color/black_cow</item>
        <item name="android:gravity">center</item>
        <item name="android:inputType">text</item>
    </style>

    <style name="CustomDialogTheme" parent="@android:style/Theme.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="dialogCornerRadius">@dimen/_20sdp</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>


    <style name="OutlinedSearchEditTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_10ssp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:maxLines">1</item>
        <item name="cursorColor">@color/electric_violet</item>
        <item name="android:textColorHint">@color/search_indicator</item>
        <item name="android:padding">@dimen/_5sdp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:drawableEnd">@drawable/search</item>
        <item name="android:drawablePadding">@dimen/_5sdp</item>
        <item name="android:drawableTint">@color/search_indicator</item>
        <item name="android:background">@drawable/outlined_bg_search_selector</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:clickable">true</item>
        <item name="android:imeOptions">actionSearch</item>
        <item name="android:inputType">text</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="FilledSearchEditTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_10ssp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:maxLines">1</item>
        <item name="cursorColor">@color/electric_violet</item>
        <item name="android:textColorHint">@color/search_indicator</item>
        <item name="android:padding">@dimen/_5sdp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:drawableStart">@drawable/search</item>
        <item name="android:drawablePadding">@dimen/_5sdp</item>
        <item name="android:drawableTint">@color/search_indicator</item>
        <item name="android:background">@drawable/filled_bg_search_selector</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:clickable">true</item>
        <item name="android:imeOptions">actionSearch</item>
        <item name="android:inputType">text</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="ProviderStatusHeaderStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_11ssp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:layout_centerVertical">true</item>

    </style>

    <style name="ProviderStatusTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_11ssp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:layout_alignParentEnd">true</item>

    </style>

    <style name="ProviderStatusViewStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_1sdp</item>
        <item name="android:background">@color/white_alpha_8</item>

    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize7Percent" parent="">
        <item name="cornerSize">7%</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize6Percent" parent="">
        <item name="cornerSizeTopLeft">6%</item>
        <item name="cornerSizeBottomLeft">6%</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="HeaderTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="BackButtonStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">@dimen/_10sdp</item>
        <item name="android:src">@drawable/back</item>
    </style>

    <style name="RoundedImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item> <!-- radius -->
    </style>


</resources>