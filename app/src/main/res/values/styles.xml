<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Font_Inter_Regular">
        <item name="fontFamily">@font/inter_regular</item>
    </style>

    <style name="Font_Inter_Medium">
        <item name="fontFamily">@font/inter_medium</item>
    </style>

    <style name="Font_Inter_Semi_Bold">
        <item name="fontFamily">@font/inter_semibold</item>
    </style>

    <style name="Font_Inter_Bold">
        <item name="fontFamily">@font/inter_bold</item>
    </style>

    <style name="Font_Inter_Extra_Bold">
        <item name="fontFamily">@font/inter_extrabold</item>
    </style>

    <style name="LabelText_Regular">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="fontFamily">@font/inter_regular</item>
    </style>

    <style name="LabelText_Medium">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="fontFamily">@font/inter_medium</item>
    </style>

    <style name="LabelText_SemiBold">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="fontFamily">@font/inter_semibold</item>
    </style>

    <style name="LabelText_Bold">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="fontFamily">@font/inter_bold</item>
    </style>

    <style name="LabelText_ExtraBold">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="fontFamily">@font/inter_extrabold</item>
    </style>

    <style name="CustomEditText" parent="Widget.AppCompat.EditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:hint">@string/playlist_name</item>
        <item name="android:importantForAutofill">no</item>
        <item name="android:inputType">text</item>
        <item name="android:textColorHint">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="CustomButtonStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">32sp</item>
    </style>

</resources>