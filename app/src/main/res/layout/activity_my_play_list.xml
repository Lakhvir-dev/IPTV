<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:bind="http://schemas.android.com/tools"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.dhiman.iptv.activity.my_play_list.MyPlayListViewModel" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splash_bg"
        android:focusable="true"
        android:focusableInTouchMode="true"
        tools:context=".activity.user_list.UserListActivity">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/_30sdp"
            android:background="@drawable/bg_inner_screen"
            android:orientation="vertical"
            android:paddingBottom="@dimen/_10sdp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivBack"
                    style="@style/BackButtonStyle"
                    android:background="@{viewModel.isFocusOnBack  ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:focusedByDefault="true"
                    android:onClick="@{viewModel::onClick}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:onFocusChange="@{viewModel::onFocusChange}"
                    bind:ignore="UnusedAttribute" />

                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                    style="@style/HeaderTextStyle"
                    android:text="@string/my_playlist"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivBack"
                    app:layout_constraintTop_toTopOf="@id/ivBack" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/_5sdp"
                android:orientation="horizontal"
                android:weightSum="2">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp">

                            <View
                                android:id="@+id/view"
                                android:layout_width="@dimen/_5sdp"
                                android:layout_height="0dp"
                                android:background="@color/flush_mahogany"
                                app:layout_constraintBottom_toBottomOf="@id/tvHeader"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="@id/tvHeader" />

                            <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                                android:id="@+id/tvHeader"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:includeFontPadding="false"
                                android:paddingStart="@dimen/_10sdp"
                                android:paddingTop="@dimen/_5sdp"
                                android:paddingEnd="0dp"
                                android:paddingBottom="@dimen/_5sdp"
                                android:text="@{viewModel.isAddNewPlayList ? @string/add_new_play_list :@string/my_playlist , default = @string/my_playlist}"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_12ssp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toEndOf="@id/view"
                                app:layout_constraintTop_toTopOf="parent" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvUserList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="@{viewModel.isAddNewPlayList ? View.GONE :View.VISIBLE , default = visible}"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            tools:listitem="@layout/list_item_category" />

                        <include
                            layout="@layout/layout_add_play_list"
                            android:visibility="@{viewModel.isAddNewPlayList ? View.VISIBLE :View.GONE , default = gone}"
                            bind:viewModel="@{viewModel}" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:weightSum="2">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/llButtonContainer"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.dhiman.iptv.util.custom_view.HelveticaMediumButton
                            android:id="@+id/btnAddPlayList"
                            style="@style/LoginButtonStyle"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="@dimen/_5sdp"
                            android:layout_weight="1"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:onClick="@{viewModel::onClick}"
                            android:padding="@dimen/_5sdp"
                            android:text="@string/add_new_playlist"
                            android:textSize="@dimen/_10ssp"
                            app:icon="@drawable/add"
                            app:iconGravity="textTop"
                            app:iconPadding="@dimen/_15sdp"
                            app:iconSize="@dimen/_24sdp"
                            app:onFocusChange="@{viewModel::onFocusChange}"
                            app:strokeColor="@{viewModel.isFocusOnAddButton ? @color/flush_mahogany :@color/beltic_sea,  default  = @color/beltic_sea}"
                            />

                        <Space
                            android:layout_width="@dimen/_10sdp"
                            android:layout_height="wrap_content" />

                        <com.dhiman.iptv.util.custom_view.HelveticaMediumButton
                            android:id="@+id/btnUpdatePlayList"
                            style="@style/LoginButtonStyle"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="@dimen/_5sdp"
                            android:layout_weight="1"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:onClick="@{viewModel::onClick}"
                            android:padding="@dimen/_5sdp"
                            android:text="@string/update_selected_playlist"
                            android:textSize="@dimen/_10ssp"
                            app:icon="@drawable/update"
                            app:iconGravity="textTop"
                            app:iconPadding="@dimen/_15sdp"
                            app:iconSize="@dimen/_24sdp"
                            app:onFocusChange="@{viewModel::onFocusChange}"
                            app:strokeColor="@{viewModel.isFocusOnUpdateButton ? @color/flush_mahogany :@color/beltic_sea,  default  = @color/beltic_sea}" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="@dimen/_2sdp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.dhiman.iptv.util.custom_view.HelveticaMediumButton
                            android:id="@+id/btnRefreshPlayList"
                            style="@style/LoginButtonStyle"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="@dimen/_5sdp"
                            android:layout_weight="1"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:onClick="@{viewModel::onClick}"
                            android:padding="@dimen/_5sdp"
                            android:text="@string/play_select_playlist"
                            android:textSize="@dimen/_10ssp"
                            app:icon="@drawable/ic_list_play"
                            app:iconGravity="textTop"
                            app:iconPadding="@dimen/_15sdp"
                            app:iconSize="@dimen/_24sdp"
                            app:onFocusChange="@{viewModel::onFocusChange}"
                            app:strokeColor="@{viewModel.isFocusOnRefreshButton ? @color/flush_mahogany :@color/beltic_sea,  default  = @color/beltic_sea}" />

                        <Space
                            android:layout_width="@dimen/_10sdp"
                            android:layout_height="wrap_content" />

                        <com.dhiman.iptv.util.custom_view.HelveticaMediumButton
                            android:id="@+id/btnDeletePlayList"
                            style="@style/LoginButtonStyle"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="@dimen/_5sdp"
                            android:layout_weight="1"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:onClick="@{viewModel::onClick}"
                            android:padding="@dimen/_5sdp"
                            android:text="@string/delete_selected_playlist"
                            android:textSize="@dimen/_10ssp"
                            app:icon="@drawable/delete"
                            app:iconGravity="textTop"
                            app:iconPadding="@dimen/_15sdp"
                            app:iconSize="@dimen/_24sdp"
                            app:onFocusChange="@{viewModel::onFocusChange}"
                            app:strokeColor="@{viewModel.isFocusOnDeleteButton ? @color/flush_mahogany :@color/beltic_sea,  default  = @color/beltic_sea}" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                </androidx.appcompat.widget.LinearLayoutCompat>

            </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>