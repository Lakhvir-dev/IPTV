<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.dhiman.iptv.dialog.automation.AutomationViewModel" />

    </data>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_dialog"
        android:gravity="center"
        android:orientation="vertical"
        tools:context=".activity.disclaimer.DisclaimerActivity">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                style="@style/DialogHeaderStyle"
                android:text="@string/set_automation"
                app:layout_constraintBottom_toBottomOf="@id/ivCross"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivCross" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivCross"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@{viewModel.isFocusOnBack  ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                android:padding="@dimen/_15sdp"
                android:src="@drawable/cross"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:onFocusChange="@{viewModel::onFocusChange}" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/_50sdp"
            android:paddingTop="@dimen/_10sdp"
            android:paddingEnd="@dimen/_50sdp"
            android:paddingBottom="@dimen/_10sdp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAutoUpdateChannel"
                style="@style/TextInputLayoutStyle"
                android:layout_marginTop="0dp"
                app:boxBackgroundColor="@{viewModel.isFocusOnChannel  ? @color/flush_mahogany_alpha_50 :@color/transparent,  default  = @color/transparent}"
                app:boxStrokeColor="@color/flush_mahogany"
                app:layout_constraintBottom_toTopOf="@id/tilAutoUpdateEpg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextInputEditTextView
                    android:id="@+id/etAutoUpdateChannel"
                    style="@style/EditTextInputLayoutStyle"
                    android:drawablePadding="@dimen/_15sdp"
                    android:onClick="@{viewModel::onClick}"
                    android:text="@string/auto_update_channels_amp_movies_daily"
                    android:textColor="@color/white"
                    app:onFocusChange="@{viewModel::onFocusChange}" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAutoUpdateEpg"
                style="@style/TextInputLayoutStyle"
                app:boxBackgroundColor="@{viewModel.isFocusOnEpg  ? @color/flush_mahogany_alpha_50 :@color/transparent,  default  = @color/transparent}"
                app:boxStrokeColor="@color/flush_mahogany"
                app:layout_constraintBottom_toTopOf="@+id/llBottomContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tilAutoUpdateChannel">

                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextInputEditTextView
                    android:id="@+id/etAutoUpdateEpg"
                    style="@style/EditTextInputLayoutStyle"
                    android:drawablePadding="@dimen/_15sdp"
                    android:onClick="@{viewModel::onClick}"
                    android:text="@string/auto_update_epg"
                    android:textColor="@color/white"
                    app:onFocusChange="@{viewModel::onFocusChange}" />

            </com.google.android.material.textfield.TextInputLayout>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llBottomContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:orientation="horizontal"
                android:weightSum="2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tilAutoUpdateEpg">

                <com.dhiman.iptv.util.custom_view.HelveticaRegularButton
                    android:id="@+id/btnCancel"
                    style="@style/AppButtonStyleIridium"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/cancel"
                    android:textSize="@dimen/_12ssp" />

                <Space
                    android:layout_width="@dimen/_10sdp"
                    android:layout_height="wrap_content" />

                <com.dhiman.iptv.util.custom_view.HelveticaRegularButton
                    android:id="@+id/btnSave"
                    style="@style/AppButtonStyleMahogany"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/save" />

            </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.appcompat.widget.LinearLayoutCompat>

</layout>