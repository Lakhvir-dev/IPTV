<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.dhiman.iptv.activity.multiScreenGrid.MultiScreenGridVM" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splash_bg"
        android:focusable="true"
        android:focusableInTouchMode="true"
        tools:context=".activity.multiScreenGrid.MultiScreenGridActivity">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/_25sdp"
            android:background="@drawable/bg_inner_screen"
            android:orientation="vertical"
            android:padding="@dimen/_5sdp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivBack"
                    style="@style/BackButtonStyle"
                    android:background="@{viewModel.isFocusOnBack ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:onClick="@{viewModel::onClick}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:onFocusChange="@{viewModel::onFocusChange}" />

                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                    style="@style/HeaderTextStyle"
                    android:text="@string/choose_grid"
                    app:layout_constraintBottom_toBottomOf="@id/ivBack"
                    app:layout_constraintStart_toEndOf="@id/ivBack"
                    app:layout_constraintTop_toTopOf="@id/ivBack" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/_5sdp"
                android:orientation="vertical"
                android:weightSum="2">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <RelativeLayout
                        android:id="@+id/rlFirstGrid"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@{viewModel.isFocusOnFirstGrid ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        app:onFocusChange="@{viewModel::onFocusChange}">

                        <ImageView
                            android:id="@+id/ivFirstGrid"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="@dimen/_10sdp"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:layout_marginEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp"
                            android:contentDescription="@string/images"
                            android:src="@drawable/ic_grid_first" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/rlSecondGrid"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@{viewModel.isFocusOnSecondGrid ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        app:onFocusChange="@{viewModel::onFocusChange}">

                        <ImageView
                            android:id="@+id/ivSecondGrid"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="@dimen/_10sdp"
                            android:contentDescription="@string/images"
                            android:src="@drawable/ic_grid_second" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/rlThirdGrid"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@{viewModel.isFocusOnThirdGrid ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        app:onFocusChange="@{viewModel::onFocusChange}">

                        <ImageView
                            android:id="@+id/ivThirdGrid"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="@dimen/_10sdp"
                            android:contentDescription="@string/images"
                            android:src="@drawable/ic_grid_third" />

                    </RelativeLayout>

                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <RelativeLayout
                        android:id="@+id/rlFourthGrid"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@{viewModel.isFocusOnFourthGrid ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        app:onFocusChange="@{viewModel::onFocusChange}">

                        <ImageView
                            android:id="@+id/ivFourthGrid"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="@dimen/_10sdp"
                            android:contentDescription="@string/images"
                            android:src="@drawable/ic_grid_fourth" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/rlFifthGrid"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@{viewModel.isFocusOnFifthGrid ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        app:onFocusChange="@{viewModel::onFocusChange}">

                        <ImageView
                            android:id="@+id/ivFifthGrid"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="@dimen/_10sdp"
                            android:contentDescription="@string/images"
                            android:src="@drawable/ic_grid_fifth" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/rlSixthGrid"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@{viewModel.isFocusOnSixthGrid ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        app:onFocusChange="@{viewModel::onFocusChange}">

                        <ImageView
                            android:id="@+id/ivSixthGrid"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="@dimen/_10sdp"
                            android:contentDescription="@string/images"
                            android:src="@drawable/ic_grid_sixth" />

                    </RelativeLayout>

                </androidx.appcompat.widget.LinearLayoutCompat>

            </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>