<?xml version="1.0" encoding="utf-8"?>
<layout>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:focusable="true"
        android:padding="@dimen/_5sdp"
       >

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/movieIv"
            android:layout_width="@dimen/_70sdp"
            android:layout_height="@dimen/_100sdp"
            android:scaleType="centerCrop"
            android:src="@drawable/avengers"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/RoundedImage" />

        <TextView
            android:id="@+id/movieNameTv"
            android:layout_width="@dimen/_10sdp"
            android:layout_height="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginStart="@dimen/_5sdp"
            android:text="5"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            android:visibility="visible"
            android:background="@drawable/bg_purple"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="@id/movieIv" />

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/_10sdp"
            android:layout_height="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginEnd="@dimen/_5sdp"
            android:text="5"
            android:src="@drawable/ic_fav_unfill"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="visible"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="@id/movieIv"  />


        <TextView
            android:id="@+id/movieTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_2sdp"
            android:text="The Avenger"
            android:visibility="visible"
            android:textColor="@color/white"
            android:textSize="@dimen/_9sdp"
            app:layout_constraintTop_toBottomOf="@id/movieIv" />


        <TextView
            android:id="@+id/movieYearTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_2sdp"
            android:text="2012"
            android:visibility="visible"
            android:textColor="@color/white"
            android:textSize="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/movieTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>