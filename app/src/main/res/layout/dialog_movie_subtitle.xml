<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.dhiman.iptv.dialog.movie_subtitile.MovieSubtitleViewModel" />

    </data>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_dialog"
        android:orientation="vertical"
        tools:context=".activity.disclaimer.DisclaimerActivity">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            >

            <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                style="@style/DialogHeaderStyle"
                android:text="@string/select_language"
                app:layout_constraintBottom_toBottomOf="@id/ivCross"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivCross" />


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivCross"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@{viewModel.isFocusOnBack  ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                android:padding="@dimen/_15sdp"
                android:src="@drawable/cross"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:onFocusChange="@{viewModel::onFocusChange}" />


        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.core.widget.NestedScrollView
            android:id="@+id/nsvBottomContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/_50sdp"
                android:paddingTop="@dimen/_5sdp"
                android:paddingEnd="@dimen/_50sdp"
                android:paddingBottom="@dimen/_5sdp">


                <com.google.android.material.textfield.TextInputLayout
                    style="@style/TextInputLayoutStyle"
                    android:layout_marginTop="0dp"
                    app:boxBackgroundColor="@{viewModel.isFocusOnEnglish  ? @color/flush_mahogany_alpha_50 :@color/transparent,  default  = @color/transparent}"
                    app:boxStrokeColor="@color/flush_mahogany"

                    >


                    <com.dhiman.iptv.util.custom_view.HelveticaMediumTextInputEditTextView
                        android:id="@+id/etEnglish"
                        style="@style/EditTextInputLayoutStyle"
                        android:onClick="@{viewModel::onClick}"
                        android:text="English"
                        android:textColor="@color/white"
                        app:onFocusChange="@{viewModel::onFocusChange}" />

                </com.google.android.material.textfield.TextInputLayout>


                <com.google.android.material.textfield.TextInputLayout
                    style="@style/TextInputLayoutStyle"
                    app:boxBackgroundColor="@{viewModel.isFocusOnArabic  ? @color/flush_mahogany_alpha_50 :@color/transparent,  default  = @color/transparent}"
                    app:boxStrokeColor="@color/flush_mahogany"
                    >

                    <com.dhiman.iptv.util.custom_view.HelveticaMediumTextInputEditTextView
                        android:id="@+id/etArabic"
                        style="@style/EditTextInputLayoutStyle"
                        android:onClick="@{viewModel::onClick}"
                        android:text="Arabic"
                        android:textColor="@color/white"
                        app:onFocusChange="@{viewModel::onFocusChange}" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/TextInputLayoutStyle"
                    app:boxBackgroundColor="@{viewModel.isFocusOnTurkish  ? @color/flush_mahogany_alpha_50 :@color/transparent,  default  = @color/transparent}"
                    app:boxStrokeColor="@color/flush_mahogany"
                    >

                    <com.dhiman.iptv.util.custom_view.HelveticaMediumTextInputEditTextView
                        android:id="@+id/etTurkish"
                        style="@style/EditTextInputLayoutStyle"
                        android:onClick="@{viewModel::onClick}"
                        android:text="Turkish"
                        android:textColor="@color/white"
                        app:onFocusChange="@{viewModel::onFocusChange}" />

                </com.google.android.material.textfield.TextInputLayout>




                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.dhiman.iptv.util.custom_view.HelveticaRegularButton
                        android:id="@+id/btnCancel"
                        style="@style/AppButtonStyleIridium"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="@string/cancel" />

                    <Space
                        android:layout_width="@dimen/_10sdp"
                        android:layout_height="wrap_content" />

                    <com.dhiman.iptv.util.custom_view.HelveticaRegularButton
                        android:id="@+id/btnSave"
                        style="@style/AppButtonStyleMahogany"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="@string/save" />

                </androidx.appcompat.widget.LinearLayoutCompat>


            </androidx.appcompat.widget.LinearLayoutCompat>


        </androidx.core.widget.NestedScrollView>


    </androidx.appcompat.widget.LinearLayoutCompat>
</layout>