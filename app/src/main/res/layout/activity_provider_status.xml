<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.dhiman.iptv.activity.provider_status.ProviderStatusViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splash_bg"
        android:focusable="true"
        android:focusableInTouchMode="true"
        tools:context=".activity.provider_status.ProviderStatusActivity">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/_30sdp"
            android:background="@drawable/bg_inner_screen"
            android:orientation="vertical"
            android:paddingBottom="@dimen/_10sdp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivBack"
                    style="@style/BackButtonStyle"
                    android:background="@{viewModel.isFocusOnBack  ? @color/white_alpha :@color/transparent,  default  = @color/transparent}"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:onClick="@{viewModel::onClick}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:onFocusChange="@{viewModel::onFocusChange}" />

                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                    style="@style/HeaderTextStyle"
                    android:text="@string/account_status"
                    app:layout_constraintBottom_toBottomOf="@id/ivBack"
                    app:layout_constraintStart_toEndOf="@id/ivBack"
                    app:layout_constraintTop_toTopOf="@id/ivBack" />

                <com.dhiman.iptv.util.custom_view.HelveticaMediumButton
                    android:id="@+id/btnLogout"
                    style="@style/AppButtonStyleMahogany"
                    android:layout_width="wrap_content"
                    android:layout_marginEnd="@dimen/_15sdp"
                    android:onClick="@{viewModel::onClick}"
                    android:text="@string/logout"
                    app:icon="@drawable/logout"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/_15sdp"
                android:paddingEnd="@dimen/_15sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/view"
                            android:layout_width="@dimen/_5sdp"
                            android:layout_height="0dp"
                            android:background="@color/flush_mahogany"
                            app:layout_constraintBottom_toBottomOf="@id/tvHeader"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tvHeader" />

                        <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                            android:id="@+id/tvHeader"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingTop="@dimen/_5sdp"
                            android:paddingEnd="0dp"
                            android:paddingBottom="@dimen/_5sdp"
                            android:text="@string/account_status"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_12ssp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/view"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_10sdp"
                                android:layout_marginBottom="@dimen/_10sdp">

                                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                                    style="@style/ProviderStatusHeaderStyle"
                                    android:text="@string/name_account" />

                                <com.dhiman.iptv.util.custom_view.HelveticaRegularTextView
                                    android:id="@+id/nameTextView"
                                    style="@style/ProviderStatusTextStyle"
                                    android:text="@string/provider" />

                            </RelativeLayout>

                            <View style="@style/ProviderStatusViewStyle" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_10sdp"
                                android:layout_marginBottom="@dimen/_10sdp">

                                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                                    style="@style/ProviderStatusHeaderStyle"
                                    android:text="@string/user_name" />

                                <com.dhiman.iptv.util.custom_view.HelveticaRegularTextView
                                    android:id="@+id/usernameTextView"
                                    style="@style/ProviderStatusTextStyle"
                                    android:text="@string/dashed_line" />

                            </RelativeLayout>

                            <View style="@style/ProviderStatusViewStyle" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_10sdp"
                                android:layout_marginBottom="@dimen/_10sdp">

                                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                                    style="@style/ProviderStatusHeaderStyle"
                                    android:text="@string/playlist_status" />

                                <com.dhiman.iptv.util.custom_view.HelveticaRegularTextView
                                    android:id="@+id/playlistStatusTextView"
                                    style="@style/ProviderStatusTextStyle"
                                    android:drawableStart="@drawable/active"
                                    android:drawablePadding="@dimen/_5sdp"
                                    android:text="@string/active"
                                    android:textColor="@color/flush_mahogany" />

                            </RelativeLayout>

                            <View style="@style/ProviderStatusViewStyle" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_10sdp"
                                android:layout_marginBottom="@dimen/_10sdp">

                                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                                    style="@style/ProviderStatusHeaderStyle"
                                    android:text="@string/expire_date" />

                                <com.dhiman.iptv.util.custom_view.HelveticaRegularTextView
                                    android:id="@+id/expireDateTextView"
                                    style="@style/ProviderStatusTextStyle"
                                    android:text="@string/dashed_line" />

                            </RelativeLayout>

                        </androidx.appcompat.widget.LinearLayoutCompat>

                        <Space
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="wrap_content" />

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_10sdp"
                                android:layout_marginBottom="@dimen/_10sdp">

                                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                                    style="@style/ProviderStatusHeaderStyle"
                                    android:text="@string/is_trail" />

                                <com.dhiman.iptv.util.custom_view.HelveticaRegularTextView
                                    android:id="@+id/isTrailTextView"
                                    style="@style/ProviderStatusTextStyle"
                                    android:text="@string/dashed_line" />

                            </RelativeLayout>

                            <View style="@style/ProviderStatusViewStyle" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_10sdp"
                                android:layout_marginBottom="@dimen/_10sdp">

                                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                                    style="@style/ProviderStatusHeaderStyle"
                                    android:text="@string/active_connections" />

                                <com.dhiman.iptv.util.custom_view.HelveticaRegularTextView
                                    android:id="@+id/activeConnectionsTextView"
                                    style="@style/ProviderStatusTextStyle"
                                    android:text="@string/dashed_line" />

                            </RelativeLayout>

                            <View style="@style/ProviderStatusViewStyle" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_10sdp"
                                android:layout_marginBottom="@dimen/_10sdp">

                                <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                                    style="@style/ProviderStatusHeaderStyle"
                                    android:text="@string/created_on_date" />

                                <com.dhiman.iptv.util.custom_view.HelveticaRegularTextView
                                    android:id="@+id/createdDateTextView"
                                    style="@style/ProviderStatusTextStyle"
                                    android:text="@string/dashed_line" />

                            </RelativeLayout>

                        </androidx.appcompat.widget.LinearLayoutCompat>

                    </androidx.appcompat.widget.LinearLayoutCompat>

                </androidx.appcompat.widget.LinearLayoutCompat>

            </androidx.core.widget.NestedScrollView>

        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>