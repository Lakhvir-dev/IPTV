<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_50sdp"
        android:layout_margin="@dimen/_2sdp"
        app:selector_background="@{@drawable/catch_up_channel_item_selector}">

        <TextView
            android:id="@+id/counterTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_5sdp"
            android:text="1"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/divider"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/_5sdp"
            android:background="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/counterTv"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/channelIv"
            android:layout_width="@dimen/_45sdp"
            android:layout_height="match_parent"
            android:layout_marginVertical="@dimen/_2sdp"
            android:layout_marginStart="@dimen/_5sdp"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/divider"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/channelNameTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_5sdp"
            android:text="@string/app_name"
            android:textColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/channelIv"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/channelInfoTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_5sdp"
            android:text="@string/app_name"
            android:textColor="@color/white"
            app:layout_constraintEnd_toStartOf="@id/channelCountTv"
            app:layout_constraintStart_toEndOf="@id/channelIv"
            app:layout_constraintTop_toBottomOf="@id/channelNameTv" />

        <TextView
            android:id="@+id/channelCountTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_5sdp"
            android:text="@string/app_name"
            android:textColor="@color/white"
            app:layout_constraintEnd_toStartOf="@id/nextIconIv"
            app:layout_constraintTop_toBottomOf="@id/channelNameTv" />

        <ImageView
            android:id="@+id/nextIconIv"
            android:layout_width="@dimen/_10sdp"
            android:layout_height="@dimen/_10sdp"
            android:layout_margin="@dimen/_5sdp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/arrow_right"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/channelNameTv" />

        <SeekBar
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_5sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/channelIv"
            app:layout_constraintTop_toBottomOf="@id/channelInfoTv" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>