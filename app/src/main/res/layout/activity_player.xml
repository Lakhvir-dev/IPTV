<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.dhiman.iptv.activity.player.PlayerViewModel" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainConstraintLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        tools:context=".activity.player.PlayerActivity">

        <com.google.android.exoplayer2.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            android:keepScreenOn="true"
            app:controller_layout_id="@layout/custom_exo_controller_view"
            app:resize_mode="fit"
            app:show_buffering="always"
            app:show_timeout="0"
            app:use_controller="true" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnUnlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_20sdp"
            android:background="@{viewModel.isFocusOnLockScreen  ? @color/white_alpha_60 :@color/transparent,  default  = @color/transparent}"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="@dimen/_10sdp"
            android:paddingVertical="@dimen/_7sdp"
            android:src="@drawable/screen_lock"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:onFocusChange="@{viewModel::onFocusChange}" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/llChannelDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_15sdp"
            app:layout_constraintTop_toTopOf="parent">

            <com.dhiman.iptv.util.custom_view.HelveticaMediumTextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:textColor="@color/white"
                android:textSize="@dimen/_12ssp" />

            <com.dhiman.iptv.util.custom_view.HelveticaRegularTextView
                android:id="@+id/tvNowPlaying"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:includeFontPadding="false"
                android:textColor="@color/white_alpha_60"
                android:textSize="@dimen/_8ssp" />

            <com.dhiman.iptv.util.custom_view.HelveticaRegularTextView
                android:id="@+id/tvNextPlaying"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:includeFontPadding="false"
                android:textColor="@color/white_alpha_60"
                android:textSize="@dimen/_8ssp" />

        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/llBottomContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="@dimen/_150sdp"
                android:layout_height="@dimen/_50sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:background="@drawable/bg_play_pause"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_marginStart="@dimen/_17sdp"
                    android:src="@drawable/backword"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_marginEnd="@dimen/_17sdp"
                    android:src="@drawable/forward"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivPlayPause"
                android:layout_width="@dimen/_50sdp"
                android:layout_height="@dimen/_50sdp"
                android:onClick="@{viewModel::onClick}"
                android:src="@{viewModel.isVideoPlay ?@drawable/video_pause_icon :@drawable/video_play_icon , default = @drawable/video_play_icon}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/llBottomContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_20sdp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ProgressBar
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="@dimen/_5sdp"
                android:layout_marginEnd="@dimen/_20sdp"
                android:progress="50"
                android:progressBackgroundTint="@color/white"
                android:progressTint="@color/flush_mahogany"
                app:layout_constraintBottom_toBottomOf="@id/btnSubtitle"
                app:layout_constraintEnd_toStartOf="@id/btnSubtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnSubtitle" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_5sdp"
                android:backgroundTint="@color/transparent"
                android:onClick="@{viewModel::onClick}"
                android:src="@drawable/subtitles"
                app:layout_constraintBottom_toBottomOf="@id/btnDisplay"
                app:layout_constraintEnd_toStartOf="@id/btnDisplay"
                app:layout_constraintTop_toTopOf="@id/btnDisplay" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_5sdp"
                android:backgroundTint="@color/transparent"
                android:onClick="@{viewModel::onClick}"
                android:src="@drawable/display"
                app:layout_constraintBottom_toBottomOf="@id/btnDisplayMode"
                app:layout_constraintEnd_toStartOf="@id/btnDisplayMode"
                app:layout_constraintTop_toTopOf="@id/btnDisplayMode" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnDisplayMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_5sdp"
                android:backgroundTint="@color/transparent"
                android:onClick="@{viewModel::onClick}"
                android:src="@drawable/screens_mode"
                app:layout_constraintBottom_toBottomOf="@id/btnLock"
                app:layout_constraintEnd_toStartOf="@id/btnLock"
                app:layout_constraintTop_toTopOf="@id/btnLock" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnLock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/transparent"
                android:onClick="@{viewModel::onClick}"
                android:src="@drawable/screen_unlock"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>