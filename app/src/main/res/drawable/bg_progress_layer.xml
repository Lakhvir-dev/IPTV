<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item> <!--Your outer blue border shape-->
        <shape android:shape="oval">
            <solid android:color="@color/black" />

            <size
                android:width="@dimen/_40sdp"
                android:height="@dimen/_40sdp" />

           <!-- <stroke
                android:width="2dp"
                android:color="@color/flush_mahogany" />-->
        </shape>
    </item>
    <!--Your inner blue Solid circle shape-->
    <item android:bottom="@dimen/_20sdp"
        android:left="@dimen/_20sdp"
        android:right="@dimen/_20sdp"
        android:top="@dimen/_20sdp">
        <shape android:shape="oval">
            <solid android:color="@color/onyx" />
        </shape>
    </item>
</layer-list>